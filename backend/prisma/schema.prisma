// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum ServiceCategory {
  CLEANING
  TUTORING
  REPAIR
  DESIGN
  WRITING
  PROGRAMMING
  MARKETING
  PHOTOGRAPHY
  VIDEO
  MUSIC
  OTHER
}

enum RequestUrgency {
  LOW
  MEDIUM
  HIGH
}

// Models
model User {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String
  name              String
  profilePicture    String?
  bio               String?
  latitude          Float?    // For geolocation support
  longitude         Float?    // For geolocation support
  averageRating     Float     @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  servicesOffered   Service[]     @relation("ServiceOwner")
  requestsCreated   ServiceRequest[] @relation("Requester")
  messagesSent      Message[]     @relation("MessageSender")
  conversationsAsParticipant1  Conversation[] @relation("Participant1")
  conversationsAsParticipant2  Conversation[] @relation("Participant2")
  reviewsGiven      Review[]      @relation("Reviewer")
  reviewsReceived   Review[]      @relation("Reviewee")
  payments          Payment[]

  @@index([email])
  @@index([createdAt])
}

model Service {
  id          String    @id @default(cuid())
  title       String
  description String
  category    ServiceCategory @default(OTHER)
  price       Float
  ownerId     String
  owner       User      @relation("ServiceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Future extension: geospatial queries
  latitude    Float?
  longitude   Float?

  @@index([ownerId])
  @@index([category])
  @@index([createdAt])
  @@index([title])
}

model ServiceRequest {
  id          String    @id @default(cuid())
  title       String
  description String
  budget      Float
  urgency     RequestUrgency @default(MEDIUM)
  requesterId String
  requester   User      @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Future extension: geospatial queries
  latitude    Float?
  longitude   Float?

  @@index([requesterId])
  @@index([urgency])
  @@index([createdAt])
  @@index([title])
}

model Conversation {
  id             String   @id @default(cuid())
  participant1Id String
  participant2Id String
  
  participant1   User    @relation("Participant1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2   User    @relation("Participant2", fields: [participant2Id], references: [id], onDelete: Cascade)
  messages       Message[]
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([participant1Id, participant2Id])
  @@index([participant1Id])
  @@index([participant2Id])
  @@index([updatedAt])
}

model Message {
  id              String    @id @default(cuid())
  content         String
  senderId        String
  conversationId  String
  
  sender          User          @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  isRead          Boolean   @default(false)
  readAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([senderId])
  @@index([conversationId])
  @@index([createdAt])
}


model Review {
  id              String    @id @default(cuid())
  rating          Int       // 1-5 stars
  comment         String?
  reviewerId      String
  reviewedUserId  String
  reviewer        User      @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewedUser    User      @relation("Reviewee", fields: [reviewedUserId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())

  // Prevent duplicate reviews
  @@unique([reviewerId, reviewedUserId])
  @@index([reviewerId])
  @@index([reviewedUserId])
  @@index([createdAt])
}

// Payments system
model Payment {
  id          String    @id @default(cuid())
  amount      Float
  currency    String    @default("USD")
  status      String    @default("pending") // pending, completed, failed
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceId   String?   // Optional: which service this payment is for
  description String?   // Payment description
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// Activity log system
model Activity {
  id          String    @id @default(cuid())
  userId      String
  action      String    // created_service, sent_message, posted_request, left_review, made_payment, etc.
  description String?   // Additional context
  resourceId  String?   // ID of the resource (serviceId, messageId, etc.)
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
